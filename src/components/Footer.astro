---
import { Icon } from 'astro-icon/components';

const year = new Date().getFullYear();

const links = [
  { href: '#services', label: 'Услуги' },
  { href: '#gallery', label: 'Галерия' },
  { href: '#pricing', label: 'Цени' },
  { href: '#contact', label: 'Контакти' },
];
---

<footer class="border-t border-[var(--color-border)] py-12">
  <div class="container-narrow">
    <div class="grid md:grid-cols-3 gap-8 mb-8">
      <div>
        <a href="#hero" class="flex items-center gap-2 font-bold text-lg mb-4">
          <Icon name="lucide:sparkles" class="text-[var(--color-accent)] w-6 h-6" />
          <span>Shine Lab</span>
        </a>
        <p class="text-sm text-[var(--color-muted)] leading-relaxed">
          Професионален детайлинг на автомобили в Пловдив.
        </p>
      </div>

      <div>
        <h4 class="font-semibold mb-4">Бързи линкове</h4>
        <ul class="space-y-2 text-sm">
          {links.map((link) => (
            <li>
              <a href={link.href} class="text-[var(--color-muted)] hover:text-[var(--color-accent)] transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="font-semibold mb-4">Контакт</h4>
        <ul class="space-y-2 text-sm text-[var(--color-muted)]">
          <li><a href="tel:+359988825799" class="hover:text-[var(--color-accent)]">+359 98 882 5799</a></li>
          <li><a href="mailto:info@shinelab.bg" class="hover:text-[var(--color-accent)]">info@shinelab.bg</a></li>
          <li>гр. Пловдив</li>
        </ul>
      </div>
    </div>

    <div class="pt-8 border-t border-[var(--color-border)] flex flex-col sm:flex-row justify-between gap-4 text-sm text-[var(--color-muted)]">
      <div>© {year} Shine Lab. Всички права запазени.</div>
      <div>Изграден с ❤️</div>
    </div>
  </div>
</footer>
