---
import { Icon } from 'astro-icon/components';

const address = 'ул. Никола Вапцаров 57, гр. Пловдив';
const mapEmbedSrc = 'https://maps.google.com/maps?q=42.12237174842921,24.744563325509418&output=embed&hl=bg&z=16';

const hours = [
  { day: 'Гъвкаво работно време', time: 'Понеделник - Неделя' }
];
---

<section id="location" class="section bg-[var(--color-surface)]/30">
  <div class="container-narrow">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <p class="text-[var(--color-accent)] font-medium mb-3 reveal">Локация</p>
      <h2 class="heading-section reveal">
        Намерете <span class="heading-accent">ни</span>
      </h2>
    </div>

    <div class="grid lg:grid-cols-3 gap-8">
      <div class="lg:col-span-2 reveal">
        <div class="rounded-2xl overflow-hidden border border-[var(--color-border)] aspect-video bg-[var(--color-surface)]">
          <iframe
            src={mapEmbedSrc}
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Карта на локацията"
          ></iframe>
        </div>
      </div>

      <div class="space-y-6">
        <div class="card reveal">
          <div class="flex items-start gap-3 mb-4">
            <Icon name="lucide:map-pin" class="w-5 h-5 text-[var(--color-accent)] mt-1 flex-shrink-0" />
            <div>
              <div class="font-semibold mb-1">Адрес</div>
              <div class="text-[var(--color-muted)] text-sm">{address}</div>
            </div>
          </div>
          <a
            href="https://www.google.com/maps/place/%D0%B6.%D0%BA.+%D0%A5%D1%80%D0%B8%D1%81%D1%82%D0%BE+%D0%91%D0%BE%D1%82%D0%B5%D0%B2+-+%D0%AE%D0%B3%D0%AE%D0%B6%D0%B5%D0%BD,+%D0%B1%D1%83%D0%BB.+%E2%80%9E%D0%9D%D0%B8%D0%BA%D0%BE%D0%BB%D0%B0+%D0%92%D0%B0%D0%BF%D1%86%D0%B0%D1%80%D0%BE%D0%B2%E2%80%9C+57,+4004+%D0%9F%D0%BB%D0%BE%D0%B2%D0%B4%D0%B8%D0%B2/@42.1222961,24.7419723,17z/data=!3m1!4b1!4m6!3m5!1s0x14acd045d24a0f41:0x899e96222db72fd6!8m2!3d42.1222922!4d24.7445526!16s%2Fg%2F11c1bh2fb9?entry=ttu&g_ep=EgoyMDI2MDQyOC4wIKXMDSoASAFQAw%3D%3D"
            target="_blank"
            rel="noopener"
            class="btn-secondary w-full justify-center text-sm"
          >
            <Icon name="lucide:navigation" class="w-4 h-4" />
            Получи упътване
          </a>
        </div>

        <div class="card reveal">
          <div class="flex items-center gap-3 mb-4">
            <Icon name="lucide:clock" class="w-5 h-5 text-[var(--color-accent)]" />
            <div class="font-semibold">Работно време</div>
          </div>
          <ul class="space-y-2 text-sm">
            {hours.map((h) => (
              <li class="flex justify-between">
                <span class="text-[var(--color-muted)]">{h.day}</span>
                <span>{h.time}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>
