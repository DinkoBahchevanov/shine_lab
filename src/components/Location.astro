---
import { Icon } from 'astro-icon/components';

const address = 'ул. [Адрес], гр. Пловдив';
const mapEmbedSrc = 'https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d11968.123!2d24.7453!3d42.1354!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNDLCsDA4JzA3LjQiTiAyNMKwNDQnNDMuMSJF!5e0!3m2!1sbg!2sbg!4v1700000000000';

const hours = [
  { day: 'Понеделник – Петък', time: '09:00 – 18:00' },
  { day: 'Събота', time: '10:00 – 16:00' },
  { day: 'Неделя', time: 'Почивен ден' },
];
---

<section id="location" class="section bg-[var(--color-surface)]/30">
  <div class="container-narrow">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <p class="text-[var(--color-accent)] font-medium mb-3 reveal">Локация</p>
      <h2 class="heading-section reveal">
        Намерете <span class="heading-accent">ни</span>
      </h2>
    </div>

    <div class="grid lg:grid-cols-3 gap-8">
      <div class="lg:col-span-2 reveal">
        <div class="rounded-2xl overflow-hidden border border-[var(--color-border)] aspect-video bg-[var(--color-surface)]">
          <iframe
            src={mapEmbedSrc}
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Карта на локацията"
          ></iframe>
        </div>
      </div>

      <div class="space-y-6">
        <div class="card reveal">
          <div class="flex items-start gap-3 mb-4">
            <Icon name="lucide:map-pin" class="w-5 h-5 text-[var(--color-accent)] mt-1 flex-shrink-0" />
            <div>
              <div class="font-semibold mb-1">Адрес</div>
              <div class="text-[var(--color-muted)] text-sm">{address}</div>
            </div>
          </div>
          <a
            href="https://maps.google.com/?q=Shine+Lab+Plovdiv"
            target="_blank"
            rel="noopener"
            class="btn-secondary w-full justify-center text-sm"
          >
            <Icon name="lucide:navigation" class="w-4 h-4" />
            Получи упътване
          </a>
        </div>

        <div class="card reveal">
          <div class="flex items-center gap-3 mb-4">
            <Icon name="lucide:clock" class="w-5 h-5 text-[var(--color-accent)]" />
            <div class="font-semibold">Работно време</div>
          </div>
          <ul class="space-y-2 text-sm">
            {hours.map((h) => (
              <li class="flex justify-between">
                <span class="text-[var(--color-muted)]">{h.day}</span>
                <span>{h.time}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>
