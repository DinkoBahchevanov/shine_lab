---
import { Icon } from 'astro-icon/components';

const links = [
  { href: '#services', label: 'Услуги' },
  { href: '#gallery', label: 'Галерия' },
  { href: '#pricing', label: 'Цени' },
  { href: '#about', label: 'За нас' },
  { href: '#contact', label: 'Контакти' },
];
---

<header class="fixed top-0 inset-x-0 z-50 backdrop-blur-md bg-[var(--color-bg)]/80 border-b border-[var(--color-border)]">
  <nav class="container-narrow flex items-center justify-between h-16">
    <a href="#hero" class="flex items-center gap-2 font-bold text-lg">
      <Icon name="lucide:sparkles" class="text-[var(--color-accent)] w-6 h-6" />
      <span>Shine Lab</span>
    </a>

    <ul class="hidden md:flex items-center gap-8 text-sm font-medium">
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            class="text-[var(--color-muted)] hover:text-[var(--color-accent)] transition-colors"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <a href="tel:+359988825799" class="btn-primary text-sm py-2 px-4">
      <Icon name="lucide:phone" class="w-4 h-4" />
      <span class="hidden sm:inline">Обади се</span>
    </a>

    <button
      id="mobile-menu-toggle"
      class="md:hidden p-2 text-[var(--color-text)]"
      aria-label="Меню"
    >
      <Icon name="lucide:menu" class="w-6 h-6" />
    </button>
  </nav>

  <div id="mobile-menu" class="md:hidden hidden border-t border-[var(--color-border)] bg-[var(--color-surface)]">
    <ul class="container-narrow py-4 space-y-3">
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            class="block py-2 text-[var(--color-muted)] hover:text-[var(--color-accent)]"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => menu.classList.add('hidden'));
  });
</script>
