---
import { Icon } from 'astro-icon/components';
import testimonials from '../data/testimonials.json';
---

<section id="testimonials" class="section">
  <div class="container-narrow">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <p class="text-[var(--color-accent)] font-medium mb-3 reveal">Отзиви</p>
      <h2 class="heading-section reveal">
        Какво казват <span class="heading-accent">клиентите</span>
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {testimonials.map((t) => (
        <article class="card reveal flex flex-col h-full">
          <div class="flex gap-1 mb-4 text-[var(--color-accent)]">
            {Array.from({ length: t.rating }).map(() => (
              <Icon name="lucide:star" class="w-5 h-5 fill-current" />
            ))}
          </div>

          <blockquote class="text-[var(--color-text)] mb-6 leading-relaxed">
            "{t.text}"
          </blockquote>

          <div class="flex items-center gap-3 pt-4 border-t border-[var(--color-border)] mt-auto">
            <div class="w-12 h-12 rounded-full bg-[var(--color-surface-hover)] overflow-hidden flex-shrink-0">
              <img src={t.avatar} alt={t.name} class="w-full h-full object-cover" loading="lazy" />
            </div>
            <div>
              <div class="font-semibold">{t.name}</div>
              <div class="text-xs text-[var(--color-muted)]">{t.service}</div>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
